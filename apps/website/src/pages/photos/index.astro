---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Page from "../../layouts/Page.astro";

const matches = import.meta.glob<{ default: ImageMetadata }>(
  "../../../public/albums/*/1.png",
  { eager: true },
);
const images = Object.values(matches);
---

<Page class="grid gap-4 grid-cols-3 md:grid-cols-6 justify-items-center">
  {
    images.map((image) => {
      const paths = image.default.src.split("/");
      const album = paths[paths.length - 2];

      return (
        <a href={`/photos/${album}`}>
          <Image
            class="border border-black @dark:border-white"
            src={image.default}
            alt=""
            height="200"
            width="200"
          />
        </a>
      );
    })
  }
</Page>
